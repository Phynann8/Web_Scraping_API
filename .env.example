PORT=3000

# Optional comma-separated API keys. If empty, auth is disabled.
API_KEYS=

# Cache + rate limiting
CACHE_TTL_SECONDS=300
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Request + storage settings
REQUEST_TIMEOUT_MS=15000
MAX_STORED_RECORDS=2000
DB_FILE=./data/scrape-results.json

# Optional user-agent override
# USER_AGENT=Mozilla/5.0
